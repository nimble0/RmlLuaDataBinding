<rml>
<head>
	<title>Test</title>
	<link type="text/rcss" href="../base.rcss"/>
	<style>
		body { font-family: rmlui-debugger-font; }
		.dynamic-title { color: #f0f; }
		.a-class { width: 100%; text-align: right; font-size: 3em; }
		outerfor h2, innerfor { display: inline-block; margin: 0.5em; }
		for, for2, outerfor { display: block; }
		#img { float: right; }
		input { border: 2px #008; }
		input:checked { background-color: #044; }

		.right { float: right; }
	</style>
	<script>
		bindings = {}

		title = "Dynamic test"
		options = {
			"play",
			"options",
			"quit"
		}
		outerList = {
			{
				title = "a",
				innerList = {
					"gold", "silver", "orange"
				}
			},
			{
				title = "b",
				innerList = {
					"iron"
				}
			},
			{
				title = "c",
				innerList = {
					"copper", "orange"
				}
			},
		}
		test3 = {
			"a",
			"b",
			"c",
			"d",
		}

		imageSrc = "icons/shield-icon.png"
		name = "pineapple"
		sensitivity = 5.0

		testDocument = nil
		lastClickEvent = ""

		function make_bindings(document)
			data_binding.make_bindings(bindings, document)
		end

		function update_bindings(document)
			data_binding.update_bindings(bindings)
		end

		function run_tests(document)
			update_bindings(document)

			local titleElement = document:GetElementById("title")
			test.assertEquals(titleElement.inner_rml, title, "bind")
			test.assert(titleElement:IsClassSet("dynamic-title"), "bind-class")
			titleElement:DispatchEvent("click", {})
			test.assert(lastClickEvent, "test1")

			local imgElement = document:GetElementById("img")
			test.assertEquals(imgElement:GetAttribute("src"), "icons/shield-icon.png", "bind-attribute-src")

			local forElements = document:GetElementsByTagName("for")
			table.remove(forElements, #forElements)
			test.assertEquals(#forElements, #options, "bind-for element count")
			for i, e in pairs(forElements) do
				local option = options[i]
				local indexBindElement = e.child_nodes[2]
				local valueBindElement = e.child_nodes[3]
				test.assertEquals(indexBindElement.inner_rml, tostring(i), "bind-for bind index")
				test.assertEquals(valueBindElement.inner_rml, option, "bind-for bind value")
			end

			local outerListForElements = document:GetElementsByTagName("outerfor")
			table.remove(outerListForElements, #outerListForElements)
			test.assertEquals(#outerListForElements, #outerList, "nested bind-for outer element count")
			for i, e in pairs(outerListForElements) do
				local data = outerList[i]
				local innerElements = {}
				for i, child in pairs(e.child_nodes) do
					if child.tag_name == "innerfor" then
						table.insert(innerElements, child)
					end
				end
				table.remove(innerElements, #innerElements)

				test.assertEquals(#innerElements, #data.innerList, "nested bind-for inner element count")
				for i, innerElement in pairs(innerElements) do
					test.assertEquals(innerElement.child_nodes[1].inner_rml, data.innerList[i], "nested bind-for bind inner element")
					innerElement:DispatchEvent("click", {})
					test.assert(lastClickEvent, innerElement.inner_rml)
				end
			end

			local forElements2 = document:GetElementsByTagName("for2")
			table.remove(forElements2, #forElements2)
			test.assertEquals(#forElements2, #test3, "bind-for element count")
			for i, e in pairs(forElements2) do
				test.assertEquals(e.inner_rml, test3[i], "bind-for bind value, same element")
			end

			local textInputElement = document:GetElementById("text-input")
			textInputElement.value = "beans"
			textInputElement:DispatchEvent("change", {value = "beans"})
			update_bindings(document)
			test.assertEquals(name, "beans", "bind-value text input")

			local selectInputElement = document:GetElementById("select-input")
			Element.As.ElementFormControlSelect(selectInputElement).selection = 2
			update_bindings(document)
			test.assertEquals(sensitivity, 2, "bind-value select input")

			local checkboxInputElement = Element.As.ElementFormControlInput(document:GetElementById("checkbox-input"))
			name = "pasta"
			update_bindings(document)
			test.assert(checkboxInputElement.checked, "bind-value checkbox input checked")
			checkboxInputElement.checked = false
			update_bindings(document)
			test.assertEquals(name, "", "bind-value checkbox input uncheck")

			local radioInputElement1 = Element.As.ElementFormControlInput(document:GetElementById("radio-input-1"))
			local radioInputElement2 = Element.As.ElementFormControlInput(document:GetElementById("radio-input-2"))
			radioInputElement1.checked = true
			update_bindings(document)
			test.assertEquals(name, "blue", "bind-value radio input")
			test.assert(radioInputElement1.checked, "bind-value radio input checked")
			test.assert(not radioInputElement2.checked, "bind-value radio input checked")
			radioInputElement2.checked = true
			update_bindings(document)
			test.assertEquals(name, "purp", "bind-value radio input")
			test.assert(not radioInputElement1.checked, "bind-value radio input checked")
			test.assert(radioInputElement2.checked, "bind-value radio input checked")
		end
	</script>
</head>
<body id="body" onload="testDocument = document">
	<button onclick="make_bindings(document)">make bindings</button>
	<button onclick="update_bindings(document)">update bindings</button>
	<h1 id="title" bind="title" bind-class="'dynamic-'..'title'" bind-event-click="print('click test1') lastClickEvent = 'test1'">Test</h1>
	<div id="main-menu-wrapper">
		<div bind-class="'a-class'">some text</div>
		<div bind-for="index, option in options">
			<for class="wrapper">repeat me <span bind="index" /> <span bind="option" /></for>
		</div>
	</div>
	<div>
		<outerfor bind-for="position in outerList">
			<h2 bind="position.title" />
			<innerfor bind-for="colour in position.innerList" bind-event-click="print('click test2', element.inner_rml) lastClickEvent = element.inner_rml">
				<span bind="colour" />
			</innerfor>
		</outerfor>
	</div>
	<img id="img" src="icons/health-icon.png" bind-attribute-src="imageSrc" />
	<for2 id="bloop" bind-for="a in test3" bind="a" />
	<input id="text-input" bind-value="data_binding.make_lens(_G, 'name')" type="text" />
	<div>name: <span bind="name" /></div>
	<div bind-event-click="name = 'orange'">set name orange</div>
	<input bind-value="data_binding.make_number_lens(_G, 'sensitivity')" type="text" />
	<div>sensitivity + 1: <span bind="sensitivity + 1" /></div>
	<select id="select-input" bind-value="data_binding.make_number_lens(_G, 'sensitivity')"">
		<option value="1">1</option>
		<option value="2">2</option>
		<option value="3">3</option>
	</select>
	<form>
		<input id="checkbox-input" type="checkbox" value="pasta" bind-checked="data_binding.make_lens(_G, 'name')" /> Pasta
		<input id="radio-input-1" type="radio" name="checky" value="blue" bind-checked="data_binding.make_lens(_G, 'name')" /> blue
		<input id="radio-input-2" type="radio" name="checky" value="purp" bind-checked="data_binding.make_lens(_G, 'name')" /> purp
	</form>
</body>
</rml>
