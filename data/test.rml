<rml>
<head>
	<title>Test</title>
	<link type="text/rcss" href="example.rcss" />
	<script>
		local reference = require("reference")
		data_binding = require("data_binding")
		R = data_binding.R(_ENV)

		function test_reference()
			local R = reference.R(_ENV)

			-- get
			a = 10
			assert(#R.a == a)

			b = { 1 }
			assert(#R.b[1] == b[1])

			c = { a = -1 }
			assert(#R.c.a == c.a)

			-- set
			R.a = 20
			assert(a == 20)

			R.b[1] = 2
			assert(b[1] == 2)

			R.c.a = -1
			assert(c.a == -1)


			-- access listeners
			local accessRef = nil
			local accessListener = function(ref)
				assert(tostring(ref) == tostring(accessRef))
			end
			reference.add_access_listener(accessListener)

			accessRef = R.a
			_ = #R.a
			accessRef = R.b[1]
			_ = #R.b[1]
			accessRef = R.b.a
			_ = #R.b.a

			reference.remove_access_listener(accessListener)


			-- dirty listeners
			local dirtyRef = nil
			local dirtyListener = function(ref)
				assert(tostring(ref) == tostring(dirtyRef))
			end
			reference.add_dirty_listener(dirtyListener)

			dirtyRef = R.a
			R.a = 5
			dirtyRef = R.b[1]
			R.b[1] = 5
			dirtyRef = R.b.a
			R.b.a = 5

			-- manual dirty
			dirtyRef = R.a
			reference.dirty_variable(R.a)

			reference.remove_dirty_listener(dirtyListener)


			print("Reference tests passed.")
		end

		test_reference()

		document = nil

		myVar = "hello"
		myColour = "red"
		myList = {"a", "b", "c"}
		myNestedList = {
			{"a", "b", "c"},
			{"1", "2", "3"},
			{"q", "w", "e"}
		}


		function make_bindings(d)
			document = d
			bindings = data_binding.make_bindings(d, _ENV)
			bindings:update()
		end

		updateCount = 0
		function test_data_binding()
			if document == nil then
				return
			end

			local bind1 = document:GetElementById("bind1")
			local bind2 = document:GetElementById("bind2")
			local bindFor1 = document:GetElementById("bind-for1")
			local bindFor2 = document:GetElementById("bind-for2")
			local bindForNested = document:GetElementById("bind-for-nested")
			local bindValue = Element.As.ElementFormControlInput(document:GetElementById("bind-value"))
			local bindChecked = Element.As.ElementFormControlInput(document:GetElementById("bind-checked"))
			local bindSubmitValue = Element.As.ElementFormControlInput(document:GetElementById("bind-submit-value"))
			local bindSubmitChecked = Element.As.ElementFormControlInput(document:GetElementById("bind-submit-checked"))
			local submitForm = Element.As.ElementForm(document:GetElementById("submit-form"))

			function set_value(element, value)
				element:SetAttribute("value", value)
				element:DispatchEvent("change", {value = value})
			end

			if updateCount == 1 then
				assert(bind1.inner_rml == myVar)
				assert(bind2.inner_rml == 'myVar = ' .. myVar)

				local i = 1
				for _, node in pairs(bindFor1.child_nodes) do
					if not node:IsClassSet("bind-for-base") then
						assert(node.inner_rml == myList[i])
						i = i + 1
					end
				end
				i = i - 1
				assert(i == #myList)

				i = 1
				for _, node in pairs(bindFor2.child_nodes) do
					if not node:IsClassSet("bind-for-base") then
						assert(math.tointeger(node:GetAttribute("index")) == i)
						assert(node.inner_rml == myList[i])
						i = i + 1
					end
				end
				i = i - 1
				assert(i == #myList)

				i = 1
				for _, outerNode in pairs(bindForNested.child_nodes) do
					if not outerNode:IsClassSet("bind-for-base") then
						local j = 1
						for _, node in pairs(outerNode.child_nodes[1].child_nodes) do
							if not node:IsClassSet("bind-for-base") then
								assert(node.inner_rml == myNestedList[i][j])
								j = j + 1
							end
						end
						j = j - 1
						assert(j == #myNestedList[i])
						i = i + 1
					end
				end
				i = i - 1
				assert(i == #myNestedList)

				assert(bindValue:GetAttribute("value") == myVar)
				assert(not bindChecked.checked)
				assert(bindSubmitValue:GetAttribute("value") == myVar)
				assert(not bindSubmitChecked.checked)

				set_value(bindValue, "world")
			elseif updateCount == 2 then
				assert(bindValue:GetAttribute("value") == myVar)
				assert(bindSubmitValue:GetAttribute("value") == myVar)

				R.myVar = "goodbye"
			elseif updateCount == 3 then
				assert(bindValue:GetAttribute("value") == myVar)
				assert(bindSubmitValue:GetAttribute("value") == myVar)

				bindChecked.checked = true
			elseif updateCount == 4 then
				assert(myColour == bindChecked:GetAttribute("value"))
				assert(bindChecked.checked)
				assert(bindSubmitChecked.checked)

				-- Update bind-submit bindings but don't apply
				set_value(bindSubmitValue, "mars")
				bindSubmitChecked.checked = true

				R.myVar = "earth"
				R.myColour = "blue"
			elseif updateCount == 5 then
				assert(myVar == "earth")
				assert(myColour == "blue")
				assert(bindSubmitValue:GetAttribute("value") == "mars")
				assert(bindSubmitChecked.checked)

				submitForm:Submit()
			elseif updateCount == 6 then
				assert(myVar == bindSubmitValue:GetAttribute("value"))
				assert(myColour == bindSubmitChecked:GetAttribute("value"))
				assert(bindSubmitChecked.checked)
			elseif updateCount == 7 then
				print("Data binding tests passed.")
			end

			updateCount = updateCount + 1
		end

		function update()
			bindings:update()

			test_data_binding()
		end
	</script>
</head>
<body onload="make_bindings(document)">
	<div id="bind1" bind="R.myVar" />

	<div id="bind2" bind="'myVar = ' .. #R.myVar" />

	<ul id="bind-for1">
		<li bind-for="v in R.myList" bind="R.v" />
	</ul>

	<ul id="bind-for2">
		<li bind-for="i, v in R.myList" bind-attribute-index="R.i" bind="R.v" />
	</ul>

	<ul id="bind-for-nested">
		<li bind-for="innerList in R.myNestedList">
			<ul>
				<li bind-for="v in R.innerList" bind="R.v" />
			</ul>
		</li>
	</ul>

	<input id="bind-value" bind-value="data_binding.make_lens(R.myVar)" type="text" />
	<input id="bind-checked" type="checkbox" value="green" bind-checked="data_binding.make_lens(R.myColour)" />

	<form id="submit-form" bind-submit>
		<input id="bind-submit-value" bind-submit-value="data_binding.make_lens(R.myVar)" type="text" />
		<input id="bind-submit-checked" type="checkbox" value="green" bind-submit-checked="data_binding.make_lens(R.myColour)" />
		<input id="bind-submit-apply" type="submit">apply</input>
	</form>
</body>
</rml>
